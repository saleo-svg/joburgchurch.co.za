---
const currentYear = new Date().getFullYear();

const footerLinks = {
  'Learn': [
    { href: '/spiritual-education', label: 'Bible Study' },
    { href: '/community-classes', label: 'Community Classes' },
    { href: '/community-classes/korean', label: 'Free Korean Class' },
    { href: '/sermons', label: 'Sermons & Series' },
  ],
  'Locations': [
    { href: '/locations/sandton', label: 'Sandton (Main)' },
    { href: '/locations/randburg', label: 'Randburg' },
    { href: '/locations/fourways', label: 'Fourways' },
    { href: '/locations/midrand', label: 'Midrand' },
    { href: '/locations/alberton', label: 'Alberton' },
    { href: '/locations/roodepoort', label: 'Roodepoort' },
    { href: '/locations/soweto', label: 'Soweto' },
  ],
  'Connect': [
    { href: '/events', label: 'Events & Calendar' },
    { href: '/gallery', label: 'Photo Gallery' },
    { href: '/blog', label: 'Blog & Articles' },
    { href: '/faq', label: 'FAQ' },
    { href: '/contact', label: 'Contact Us' },
  ],
  'Visit': [
    { href: '/visit', label: 'Plan Your Visit' },
    { href: '/youth-usecan', label: 'Youth Programs' },
    { href: '/about', label: 'About Us' },
  ],
  'About': [
    { href: '/about', label: 'Our Story' },
    { href: '/privacy', label: 'Privacy Policy' },
  ],
};
---

<footer class="border-t border-gray-200 bg-gray-50">
  <!-- Decorative skyline banner -->
  <div class="w-full overflow-hidden" style="height: 80px;">
    <img
      src="/images/footer-skyline.svg"
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover"
      loading="lazy"
    />
  </div>
  <div class="container-max section-padding pt-8">
    <div class="grid grid-cols-2 gap-6 lg:grid-cols-6">
      <!-- Brand -->
      <div class="col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-gray-900">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6 text-blue-600" aria-hidden="true">
            <path d="M12 2v20M2 12h20" />
          </svg>
          <span class="text-sm lg:text-base">Johannesburg Bible Study Church</span>
        </a>
        <p class="mt-4 text-sm text-gray-600">
          A Bible study and welcoming Christian community in Sandton, Johannesburg.
        </p>
        <p class="mt-2 text-sm text-gray-500">
          Parkmore, 11th Street, Sandton, 2196<br />
          Johannesburg, South Africa
        </p>
      </div>

      <!-- Links -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wide">
            {category}
          </h3>
          <ul class="mt-4 space-y-2">
            {links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-600 hover:text-blue-600 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 grid gap-8 sm:grid-cols-3 border-t border-gray-200">
      <div>
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-3">
          Weekly Bible Study
        </h3>
        <p class="text-sm text-gray-600">
          Wednesday, 7:30pm<br />
          Online via Google Meet
        </p>
        <p class="text-xs text-gray-500 mt-1">Open to all · Free</p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-3">
          Free Korean Class
        </h3>
        <p class="text-sm text-gray-600">
          Sunday, 2:00pm<br />
          Parkmore, Sandton
        </p>
        <p class="text-xs text-gray-500 mt-1">Appointment required</p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-3">
          In-Person Bible Study
        </h3>
        <p class="text-sm text-gray-600">
          First Saturday of the month, 4:00pm<br />
          Parkmore, Sandton
        </p>
        <p class="text-xs text-gray-500 mt-1">Same passage as Wednesday</p>
      </div>
    </div>

    <div class="mt-8 border-t border-gray-200 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} Johannesburg Bible Study Church. All rights reserved.
      </p>
      <p class="text-sm text-gray-400">
        Bible study community in Sandton, Johannesburg
      </p>
    </div>
  </div>
</footer>
