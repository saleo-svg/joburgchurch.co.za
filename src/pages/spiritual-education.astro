---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Bible Study in Sandton Johannesburg | Wednesday Online Bible Study"
  description="Join our Wednesday online Bible study in Sandton, Johannesburg. Wednesday 7:30pm via Google Meet. A welcoming Bible study community in the heart of Johannesburg."
>
  <section class="section-padding">
    <div class="container-max">
      <p class="text-blue-600 font-semibold uppercase tracking-wide text-sm mb-2">
        Spiritual Education
      </p>
      <h1 class="heading-1 mb-6">Bible Study in Sandton, Johannesburg</h1>
      <p class="text-body max-w-3xl mb-8">
        Our Wednesday online Bible study is the heart of Johannesburg Bible Study Church. Join us every Wednesday at 7:30pm via Google Meet for an in-depth exploration of Scripture — open to everyone in the Johannesburg and Sandton area.
      </p>
    </div>
  </section>

  <section class="section-padding bg-gray-50">
    <div class="container-max">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <h2 class="heading-2 mb-6">Wednesday Bible Study</h2>
          <div class="card space-y-4 mb-6">
            <div class="flex gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              <div>
                <p class="font-semibold text-gray-900">Every Wednesday</p>
                <p class="text-sm text-gray-600">7:30pm South African time</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              <div>
                <p class="font-semibold text-gray-900">Online via Google Meet</p>
                <p class="text-sm text-gray-600">Join from anywhere in Johannesburg or beyond</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
              <div>
                <p class="font-semibold text-gray-900">Open to Everyone</p>
                <p class="text-sm text-gray-600">No church membership required</p>
              </div>
            </div>
          </div>
          <a href="/contact" class="btn-primary">Join Our Bible Study</a>
        </div>

        <div>
          <h2 class="heading-2 mb-6">Our Bible Study Focus</h2>
          <div class="space-y-4">
            {[
              {
                title: 'Bible Study in Johannesburg',
                desc: 'We study the Bible systematically, exploring both Old and New Testament passages with attention to their meaning for today.',
              },
              {
                title: 'Heart Education',
                desc: 'Our Bible study goes beyond information to transformation — exploring how Scripture shapes our character, relationships, and daily choices.',
              },
              {
                title: 'Practical Application',
                desc: 'Each session connects Bible teaching to real-life situations faced by people in Sandton, Johannesburg, and beyond.',
              },
              {
                title: 'Community Discussion',
                desc: 'Our online format encourages open questions and honest discussion — creating space for everyone to grow together.',
              },
            ].map((item) => (
              <div class="flex gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                <div>
                  <p class="font-semibold text-gray-900">{item.title}</p>
                  <p class="text-sm text-gray-600">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- More Programs -->
  <section class="section-padding">
    <div class="container-max">
      <h2 class="heading-2 mb-8">All Spiritual Education Programs</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <div class="card">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-blue-100 text-blue-700 font-bold mb-3">BS</div>
          <h3 class="heading-3 mb-2">Wednesday Bible Study</h3>
          <p class="text-sm text-gray-600 mb-3">Online via Google Meet, 7:30pm every Wednesday. Open to all.</p>
          <p class="text-xs text-blue-600 font-semibold">Every Wednesday, 7:30pm</p>
        </div>
        <div class="card">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-amber-100 text-amber-700 font-bold mb-3">KC</div>
          <h3 class="heading-3 mb-2">Free Korean Class</h3>
          <p class="text-sm text-gray-600 mb-3">Free Korean language class every Sunday in Sandton. Open to all community members.</p>
          <p class="text-xs text-amber-600 font-semibold">Sunday 2:00pm</p>
        </div>
        <div class="card">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-green-100 text-green-700 font-bold mb-3">YP</div>
          <h3 class="heading-3 mb-2">Youth Programs</h3>
          <p class="text-sm text-gray-600 mb-3">UseCan youth empowerment, leadership development, and community service projects.</p>
          <p class="text-xs text-green-600 font-semibold">Summer / Winter schedule</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
