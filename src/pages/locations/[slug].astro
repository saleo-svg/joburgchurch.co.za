    areaNotes: [
      'Fourways connects people from northern Johannesburg who are looking for Bible study, Christian fellowship, and a welcoming community.',
      'Contact us before visiting so we can share the current group schedule or suggest the Wednesday online Bible study if that is simpler.',
    ],
  },
  midrand: {
    name: 'Midrand',
    tagline: 'Bible study community in Midrand, Johannesburg',
    headline: 'Bible Study Church in Midrand, Johannesburg',
