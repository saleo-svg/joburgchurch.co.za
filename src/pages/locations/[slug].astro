  },
  randburg: {
    name: 'Randburg',
    tagline: 'Bible study community in Randburg, Johannesburg',
    headline: 'Bible Study Church in Randburg, Johannesburg',
    description: 'A Bible study and Christian community gathering in Randburg, Johannesburg. Join us as we explore the Bible together and grow in faith.',
