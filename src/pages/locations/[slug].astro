---
import BaseLayout from '@/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'sandton' } },
    { params: { slug: 'randburg' } },
    { params: { slug: 'fourways' } },
    { params: { slug: 'midrand' } },
    { params: { slug: 'alberton' } },
    { params: { slug: 'roodepoort' } },
    { params: { slug: 'soweto' } },
  ];
}

