    metaDesc: 'Find a Bible study church in Randburg, Johannesburg. A welcoming Christian community gathering in the Randburg area.',
    address: 'Randburg, Johannesburg',
    cta: 'Join Our Bible Study in Randburg',
    areaNotes: [
      'Randburg is ideal for people searching for a Bible study group near Ferndale, Blairgowrie, Linden, Cresta, and surrounding suburbs.',
      'Schedules may vary by season, so please call first and we will connect you with the best available Johannesburg Bible study option.',
    ],
  },
  fourways: {
    name: 'Fourways',
    tagline: 'Bible study community in Fourways, Johannesburg',
    headline: 'Bible Study Church in Fourways, Johannesburg',
    description: 'A Bible study and Christian community gathering in Fourways, Johannesburg. Explore the Bible together in a warm and welcoming environment.',
