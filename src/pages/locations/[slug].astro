const loc = locationData[slug];
---

<BaseLayout
  title={loc.metaTitle}
  description={loc.metaDesc}
>
  <section class="section-padding">
    <div class="container-max">
      <a href="/locations" class="text-sm text-blue-600 hover:underline mb-6 inline-block">All Locations</a>
      <p class="text-blue-600 font-semibold uppercase tracking-wide text-sm mb-2">{loc.name}, Johannesburg</p>
      <h1 class="heading-1 mb-6">{loc.headline}</h1>
      <p class="text-body max-w-3xl mb-8">{loc.description}</p>
    </div>
  </section>

  <section class="section-padding bg-gray-50">
    <div class="container-max">
      <h2 class="heading-2 mb-8">Programs at {loc.name}</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {loc.programs.map((program) => (
          <div class="card">
            <div class="flex items-start justify-between mb-3">
              <h3 class="heading-3">{program.title}</h3>
              <span class:list={['text-xs px-2 py-1 rounded-full font-medium', program.type === 'Online' ? 'bg-blue-100 text-blue-700' : 'bg-amber-100 text-amber-700']}>
                {program.type}
              </span>
            </div>
            <p class="text-sm font-medium text-gray-900 mb-1">{program.time}</p>
            <p class="text-xs text-gray-500">{program.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {slug === 'sandton' && (
    <section class="section-padding bg-amber-50">
      <div class="container-max">
        <div class="max-w-2xl">
          <h2 class="heading-2 mb-4">Free Korean Class — Sunday 2:00pm</h2>
          <p class="text-body mb-4">
            Our free Korean class is held every Sunday at 2:00pm at our Sandton venue. It is open to everyone in the Johannesburg community — no church membership required.
          </p>
          <p class="text-sm text-gray-600 mb-6">Appointments required. Call to register.</p>
          <div class="card space-y-2 mb-6">
            <p class="text-sm font-semibold text-gray-500">Hotline</p>
            <p>Mr. Sim: <a href="tel:+27774871295" class="text-blue-600 hover:underline">+27 77 487 1295</a></p>
            <p>Ms. Dora: <a href="tel:+27674424461" class="text-blue-600 hover:underline">+27 67 442 4461</a></p>
          </div>
          <a href="/community-classes/korean" class="btn-primary">Korean Class Details</a>
        </div>
      </div>
    </section>
  )}

  <section class="section-padding">
    <div class="container-max">
      <div class="max-w-2xl">
        <h2 class="heading-2 mb-4">Get In Touch</h2>
        <p class="text-body mb-6">
          For enquiries about Bible study groups in {loc.name} or any of our programs, please contact us by phone.
        </p>
        <div class="card space-y-2 mb-6">
          <p class="text-sm font-semibold text-gray-500">Phone</p>
          <p>Mr. Sim: <a href="tel:+27774871295" class="text-blue-600 hover:underline">+27 77 487 1295</a></p>
          <p>Ms. Dora: <a href="tel:+27674424461" class="text-blue-600 hover:underline">+27 67 442 4461</a></p>
        </div>
        <p class="text-sm text-gray-500">
          You can also visit our main location in Sandton for our Wednesday online Bible study and Sunday Korean class.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-gray-50">
    <div class="container-max">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <h2 class="heading-2 mb-4">Bible Study Near {loc.name}</h2>
          <p class="text-body">
            If you are searching for Bible study near me in {loc.name}, church near me in Johannesburg, or a Christian community where you can ask questions and grow, we would be glad to help you find the right next step.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {loc.areaNotes.map((note) => (
            <div class="card">
              <p class="text-sm text-gray-600">{note}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-blue-50">
    <div class="container-max text-center">
      <h2 class="heading-2 mb-4">Other Locations in Johannesburg</h2>
      <div class="flex flex-wrap gap-2 justify-center mb-6">
        {['Sandton', 'Randburg', 'Fourways', 'Midrand', 'Alberton', 'Roodepoort', 'Soweto'].filter(n => n !== loc.name).map(n => (
          <a href={`/locations/${n.toLowerCase()}`} class="text-sm bg-white border border-gray-200 px-3 py-1 rounded-full text-gray-700 hover:border-blue-300 hover:text-blue-700 transition-colors">
            {n}
          </a>
        ))}
      </div>
      <a href="/locations" class="btn-secondary">View All Locations</a>
    </div>
  </section>
</BaseLayout>
