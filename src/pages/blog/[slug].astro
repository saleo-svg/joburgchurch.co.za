---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getBlogPostSchema } from '@/components/Schema';

export function getStaticPaths() {
  return [
    { params: { slug: 'welcome-to-our-church' } },
    { params: { slug: 'free-korean-class-community' } },
    { params: { slug: 'why-community-learning-matters' } },
    { params: { slug: 'youth-growth-spiritual-education' } },
    { params: { slug: 'how-to-join-online-bible-study' } },
    { params: { slug: 'what-to-expect-first-bible-study' } },
    { params: { slug: 'learning-korean-as-an-adult-sandton' } },
    { params: { slug: 'finding-community-as-a-young-adult-johannesburg' } },
    { params: { slug: 'bible-study-near-me-johannesburg' } },
  ];
}

const { slug } = Astro.params;

const posts = {
  'welcome-to-our-church': {
    title: 'Welcome to Our Bible Study Community in Johannesburg',
    date: '2026-01-01',
    excerpt: 'We are glad you are here. Johannesburg Bible Study Church is a welcoming Bible study and Christian community in Sandton, Johannesburg.',
    tags: ['Community', 'Welcome'],
    content: `
      <p>We are glad you are here. Johannesburg Bible Study Church is a welcoming Bible study and Christian community in Sandton, Johannesburg. We invite you to discover what we are about.</p>
      <h2>A Bible Study Community in Sandton</h2>
      <p>Our church is built around Bible study. Every Wednesday evening, we gather online for a Bible study that is thoughtful, accessible, and relevant to everyday life in Johannesburg. Whether you are new to the Bible or have been studying it for years, you will find a warm welcome here.</p>
      <h2>Beyond Bible Study</h2>
      <p>We also offer free community classes — including our popular Sunday Korean class — and youth programs through our UseCan initiative. These are open to everyone in the Sandton and Johannesburg community.</p>
      <h2>A Place to Belong</h2>
      <p>Whether you are exploring faith for the first time, returning to church after a while, or looking for a new community to be part of — you are welcome here. Come as you are.</p>
    `,
  },
  'free-korean-class-community': {
    title: 'Free Korean Class for the Sandton and Johannesburg Community',
    date: '2026-02-01',
    excerpt: 'Our free Korean class is open to everyone in Sandton and greater Johannesburg. Sunday 2:00pm, appointment required.',
    tags: ['Korean Class', 'Community'],
    content: `
      <p>Learning a new language opens doors — to new cultures, new friendships, and new opportunities. That is why Johannesburg Bible Study Church offers a free Korean class to the Sandton and Johannesburg community.</p>
      <h2>Who Can Join?</h2>
      <p>Anyone. You do not need to be a church member. You do not need any previous experience. Whether you are a complete beginner or already know some Korean, you are welcome.</p>
      <h2>What You Will Learn</h2>
      <p>We start with the Korean alphabet (Hangul) on day one. From there, we build everyday conversation skills — greetings, introductions, shopping, ordering food, and more. We also explore Korean culture and customs.</p>
      <h2>Class Details</h2>
      <p>The Korean class runs every Sunday at 2:00pm at our venue in Parkmore, Sandton. It is completely free. Appointments are required — please call to register before attending.</p>
      <p>Contact: Mr. Sim (+27 77 487 1295) or Ms. Dora (+27 67 442 4461)</p>
    `,
  },
  'why-community-learning-matters': {
    title: 'Why Community Learning Matters in Johannesburg',
    date: '2026-03-01',
    excerpt: 'When a church opens its doors to serve the community through free education and skills programs, everyone benefits.',
    tags: ['Education', 'Community'],
    content: `
      <p>Education changes lives. When a community comes together to learn — regardless of age, background, or income — something powerful happens.</p>
      <h2>A Church That Serves</h2>
      <p>At Johannesburg Bible Study Church, we believe our calling extends beyond our Wednesday Bible study. We want to be a resource for the people of Sandton and greater Johannesburg in practical ways.</p>
      <p>That is why we offer free classes — including our Sunday Korean class. These are not programs to attract people to church. They are genuine acts of service to our neighbourhood.</p>
      <h2>Learning Together Builds Community</h2>
      <p>When people learn together, they grow together. Our Korean class brings together people who might never otherwise meet — different ages, backgrounds, and life situations, united by a shared goal. That is the beginning of real community.</p>
    `,
  },
  'youth-growth-spiritual-education': {
    title: 'Youth Growth and Spiritual Education in Sandton',
    date: '2026-04-01',
    excerpt: 'Supporting young people in their spiritual journey is one of the most important things a church community can do.',
    tags: ['Youth', 'Spiritual Growth'],
    content: `
      <p>Youth is a time of discovery — discovering who you are, what you believe, and where you belong. A supportive community can make all the difference in that journey.</p>
      <h2>Our Youth Programs</h2>
      <p>At Johannesburg Bible Study Church, we have designed our youth programs with one question in mind: what do young people actually need? The answer is often the same across cultures and contexts: belonging, purpose, and someone who believes in them.</p>
      <h2>UseCan — You Can</h2>
      <p>UseCan is our youth initiative built around empowerment. We create space for young people in Sandton and Johannesburg to grow spiritually, build leadership skills, serve their community, and discover their unique gifts. We believe every young person can make a meaningful contribution.</p>
    `,
  },
  'how-to-join-online-bible-study': {
    title: 'How to Join Our Wednesday Online Bible Study in Johannesburg',
    date: '2026-05-01',
    excerpt: 'Thinking about joining our Wednesday online Bible study in Sandton? Here is everything you need to know to get started.',
    tags: ['Bible Study', 'Online'],
    content: `
      <p>Our Wednesday online Bible study is the heart of Johannesburg Bible Study Church. Held every Wednesday at 7:30pm via Google Meet, it is open to everyone in the Johannesburg and Sandton area.</p>
      <h2>What Is the Wednesday Bible Study?</h2>
      <p>Each Wednesday evening, we study a passage of the Bible together. Our approach is thoughtful and accessible — we read the text carefully, discuss its meaning, and think about how it applies to our lives today. There is always space for questions.</p>
      <h2>How to Join</h2>
      <p>Contact us by phone and we will send you the Google Meet link. There is no cost and no commitment required — just show up and join the conversation.</p>
      <p>Phone: +27 77 487 1295</p>
      <h2>What to Expect</h2>
      <p>A typical session lasts about 90 minutes. We start with a short time of fellowship, move into the Bible study discussion, and end with prayer. The atmosphere is relaxed and welcoming — perfect for both beginners and those more advanced in their faith.</p>
    `,
  },
  'what-to-expect-first-bible-study': {
    title: 'What to Expect at Your First Bible Study (Even If You Have Never Opened a Bible)',
    date: '2026-06-10',
    excerpt: 'You do not need to know anything about the Bible to join us on a Wednesday evening in Johannesburg. Here is what a first session actually looks like, and why most people wish they had started sooner.',
    tags: ['Bible Study', 'Beginners'],
    content: `
      <p>If you have never been to a Bible study before, the idea of walking into one is a little strange. Maybe you picture a room full of people quoting chapter and verse, or someone pointing fingers and telling you what to believe. That is not what happens in our Wednesday evenings in Johannesburg — and it is not what most people who have never been to a Bible study actually end up finding.</p>
      <h2>The ten minutes before we start</h2>
      <p>We open the Google Meet at 7:20pm. The first ten minutes are honestly a little awkward in the best way — people are logging in, their coffee is not quite ready, the dog is barking somewhere, somebody is still on the train between Park and Rosebank. By 7:30pm, the screen is full of faces and we get going. You will probably recognise the moment. It is the same small chaos as any group of people settling in after a long day.</p>
      <h2>The actual Bible study</h2>
      <p>We do one passage, slowly. Last month it was the short letter of Paul to Philemon — four short chapters, one runaway slave, one Christian slave owner, one older friend trying to hold the two together. We read it out loud together. Then we ask three simple questions. What is the passage actually saying? What would it have meant to the first people who read it? Where do we see ourselves in it tonight?</p>
      <p>You do not need to have an answer. You do not need to know what the book of Philemon is. You do not even need to bring a Bible — we put the text on screen. Most people who join us for the first time just listen for the first twenty minutes. By the second half, they are asking questions. That is normal.</p>
      <h2>The part nobody warns you about</h2>
      <p>Honest moment — the Bible study itself is usually the second most important thing that happens on a Wednesday night. The first is the five or ten minutes after, when nobody closes the tab. Someone from Randburg is asking Mr. Sim whether the next session will be on Colossians. A first-year student from Wits is telling Ms. Dora about a paper she is writing. Two regulars are debating whether Psalm 23 is really about sheep or really about rest. You will probably log off a little later than you planned. Most of us do.</p>
      <h2>What to bring, what to wear, what to expect</h2>
      <p>You. That is the only thing you need to bring. Wear whatever you would wear to work from home. Have a coffee or a glass of water. Turn your camera on if you want, leave it off if you do not — both are completely fine. The Google Meet link is sent out the day before. If you cannot find it, call Mr. Sim on +27 77 487 1295 and he will resend it.</p>
      <h2>What if I have questions I am too embarrassed to ask the group?</h2>
      <p>Save them. Bring them to the second session. Or call us during the week. There is no question that has surprised us in the last ten years of running this Bible study in Johannesburg — and the ones that feel most embarrassing to you are almost always the ones that start the best conversation in the room.</p>
      <h2>What next?</h2>
      <p>If you have read this far and you are still not sure, that is also a good reason to come. The first Wednesday is the hardest one. The second one is much easier. By the third one, you will probably start looking forward to it. That is the experience most of our regulars describe, and it is the experience we hope you will have too.</p>
      <p>To get the Google Meet link, call +27 77 487 1295 or +27 67 442 4461 any weekday.</p>
    `,
  },
  'learning-korean-as-an-adult-sandton': {
    title: 'Learning Korean as an Adult in Sandton: Six Honest Reasons to Try Our Free Class',
    date: '6/15/2026',
    excerpt: 'A free Sunday Korean class in Parkmore, Sandton — sounds too good to be true. Here is what actually happens each week, who shows up, and why adults keep coming back.',
    tags: ['Korean Class', 'Adult Learning'],
    content: `
      <p>Every Sunday at 2pm in Parkmore, a small group of adults who have never met before sit down and learn how to say hello in Korean. The class is free. The class is also, somehow, one of the most useful things several of them do all week. Here is what actually happens, told without the brochure language.</p>
      <h2>1. You will not be the only beginner</h2>
      <p>Most people who show up on their first Sunday are exactly where you are. They have wanted to learn Korean for years, watched the dramas, listened to the music, never quite got around to opening a textbook. About two thirds of the room is in the same boat. The other third is further along and remembers being where you are. Nobody is judging anybody. We are very clear about that on the first day.</p>
      <h2>2. We start with Hangul, the alphabet, on day one</h2>
      <p>This is the part that surprises people. Korean is one of the most logical writing systems in the world. Within ninety minutes, you will be able to read the words on the menu of a Korean restaurant. By the end of the second Sunday, you will be sounding things out on packaging at home. It is honestly one of the most satisfying small wins of adult life.</p>
      <h2>3. The class is in Parkmore, on a Sunday afternoon</h2>
      <p>Parkmore sits between Sandton City and Hyde Park. There is parking. It is on the way home from a weekend in the city. It is not on a school night. Coming in for two hours on a Sunday feels manageable even during a busy work week, which is why so many of our regulars have been coming for over a year.</p>
      <h2>4. There is no textbook to buy</h2>
      <p>We provide everything. You do not need a laptop. You do not need an app. You do not need to have studied anything in advance. Bring a pen if you want to take notes. That is the only thing we ask.</p>
      <h2>5. It is genuinely free, and it has been for years</h2>
      <p>This is a community class run out of our Bible study church in Sandton. There is no membership fee, no registration fee, no hidden charges. The only reason we ask you to book in advance is so we know how many seats to set up. Call Mr. Sim on +27 77 487 1295 or Ms. Dora on +27 67 442 4461.</p>
      <h2>6. You will probably make a friend</h2>
      <p>Some of the strongest friendships in our Sandton community started in this class. People who would never have crossed paths in their normal week — different jobs, different suburbs, different life stages — end up going for coffee after the second Sunday. We did not design that. It just happens, and we have stopped being surprised by it.</p>
      <h2>Who is the class for, really?</h2>
      <p>If you have wanted to learn Korean for a long time and never had a reason to start, this is your reason. If you are between jobs, between semesters, between life stages, and you want something for yourself on a Sunday, this is also a good reason. You do not need to be Christian, you do not need to be a member of the church, and you do not need to be young. The average age of a Sunday class sits somewhere in the late twenties to mid forties, and we have had people both younger and older fit in perfectly.</p>
      <h2>What if I miss a week?</h2>
      <p>Come the next week. There is no rolling enrolment and no syllabus you can fall behind on. Each session is built to be useful on its own. If you miss three in a row, send a message and we will catch you up before you come back.</p>
      <h2>How to book</h2>
      <p>Call or WhatsApp Mr. Sim on +27 77 487 1295, or Ms. Dora on +27 67 442 4461, any day of the week. Tell us your name and that you would like to come to the Sunday Korean class in Sandton. We will confirm the time and the address in Parkmore, and we will see you on Sunday at 2pm.</p>
    `,
  },
  'finding-community-as-a-young-adult-johannesburg': {
    title: 'Finding Community as a Young Adult in Johannesburg (Without Forcing It)',
    date: '2026-06-20',
    excerpt: 'Moving to Johannesburg for university or your first job is exciting and lonely at the same time. Here is how UseCan and our Wednesday evenings have become a soft landing place for young adults across Sandton, Randburg, and Midrand.',
    tags: ['Youth', 'Community'],
    content: `
      <p>There is a particular kind of lonely that comes with being twenty-two in Johannesburg. You moved here for university, or for a job, or because everyone else seemed to. You have a place to live, a roommate you like most days, a routine. You go out on weekends. And on a Tuesday evening, somewhere around 9pm, you realise you have not had a real conversation with anyone in three days.</p>
      <p>This post is for that person.</p>
      <h2>The problem with trying to make friends as an adult</h2>
      <p>Most of the advice about making friends in your twenties is written for people who already have a friend group to start with. Join a club, the advice says. Volunteer for something. Take a class. None of that is bad advice. None of it actually works if you are the kind of person who walks into a room of strangers and immediately wants to leave. Most of us are that kind of person.</p>
      <h2>Why UseCan works differently</h2>
      <p>UseCan is the youth programme we run out of our Bible study community in Sandton. The reason it works for young adults in Johannesburg is that nobody is asked to perform. You are not pitching yourself to a networking group. You are not introducing yourself to a circle of people who have known each other since boarding school. You are showing up to a Wednesday evening, sitting down, and being part of a Bible study that has been running for ten years. By the second week, somebody remembers your name. By the fourth week, somebody asks how your week was. By the eighth week, you realise this is just your life now.</p>
      <h2>The soft landing we did not plan for</h2>
      <p>When we started UseCan, it was for teenagers. Then we noticed the same thing kept happening. University students from Wits and UJ, young professionals new to Johannesburg, people who had moved here from Durban or Cape Town or Pretoria, would show up because a friend had dragged them along. They would stay because nobody asked them to be anything other than curious. The Bible study became a soft landing place. People came for the Wednesday night and stayed for the friendships.</p>
      <h2>What you actually do on a Wednesday</h2>
      <p>Honestly, less than you think. The Bible study itself runs about an hour. The hour after is when the real thing happens. We sit around, drink tea, argue about theology, talk about jobs, talk about parents, talk about whether to move back home, talk about whether to stay. We have watched several couples meet in that hour after. We have watched several friendships last long after people moved on from Johannesburg.</p>
      <h2>Where we are, and who shows up</h2>
      <p>The main evening is Wednesday at 7:30pm, online via Google Meet, so the room includes people from Sandton, Randburg, Midrand, Fourways, and a few from further out. We also run an in-person session in Parkmore once a month for anyone who wants to meet face to face. The age range of UseCan has stretched to include people from about eighteen to mid-thirties, and the room works because the people in it are mostly at a similar life stage: figuring things out, open to honest conversation, not trying to be impressive.</p>
      <h2>If you are not sure</h2>
      <p>Call Mr. Sim on +27 77 487 1295 any weekday and ask whether UseCan is a fit for where you are right now. There is no commitment, no signup form, and no one will follow up with a guilt message if you do not come back. The Wednesday evening is what it is. It might not be for you. It might be exactly the thing you have been looking for in Johannesburg for the last six months. The only way to know is to try one.</p>
    `,
  },
  'bible-study-near-me-johannesburg': {
    title: 'Bible Study Near Me in Johannesburg: Why Online Actually Works Better',
    date: '2026-06-25',
    excerpt: 'Searching for a Bible study near you in Johannesburg or Sandton? Before you drive across town on a Wednesday night, read this — most of our regulars joined from their couches first.',
    tags: ['Bible Study', 'Online'],
    content: `
      <p>If you have just typed "Bible study near me" into Google and ended up in Sandton, welcome. You are in the right place. Before you do anything else, let us save you about six months of trial and error.</p>
      <h2>What most people actually want from a Bible study</h2>
      <p>When people search for a Bible study near them in Johannesburg, they are usually not looking for the closest possible building. They are looking for the closest possible community. They want a place where the conversation is real, where the questions are welcome, where they do not have to pretend to know more than they do, and where they can show up in normal clothes on a weeknight. That is a much harder thing to find than a building with a Bible study sign on the door.</p>
      <h2>Why online works for Johannesburg</h2>
      <p>Sandton to Randburg at 7:15pm on a Wednesday is not a fun drive. Parkmore to Roodepoort on the same night is worse. Joburg traffic does not care that you are trying to do something good with your evening. The honest truth is that, for most of the people in our Bible study community, the Google Meet option is the only reason they have been able to keep coming back week after week.</p>
      <p>Since 2020, the Wednesday evening has run online. The room has grown. The conversations have got more honest, not less. Several people in the Bible study today have never once set foot in Parkmore, and they are some of the most regular people in the room. Geography stopped being a reason not to be part of the community, and the community got better for it.</p>
      <h2>What you get from a Bible study that is online</h2>
      <p>You get the actual Bible study. You get the conversation. You get the slightly chaotic ten minutes before and after when people are arguing about the previous week and catching up on life. You get the chance to ask the question you have been sitting with for a month. You do not have to commute. You do not have to find parking. You can be in your kitchen in your pyjamas with a cup of coffee. Nobody cares what you are wearing.</p>
      <h2>What you do not get, and what we do about it</h2>
      <p>You do not get the hand on the shoulder after a hard week. You do not get the cup of tea that someone puts in your hand without asking. We knew this was a real loss, so a few years in we added a once-a-month in-person evening in Parkmore for anyone who wants a face to put next to the name. The Wednesday stays online. The Saturday evening is in person. Both are part of the same community.</p>
      <h2>What if I am not in Johannesburg?</h2>
      <p>Several of our regulars are not in Johannesburg at all. They moved to Cape Town, to Durban, to London, to Sydney, and they still join the Wednesday Bible study from their new kitchen. The community has followed them. That is one of the things we did not see coming, and it has been a quiet gift.</p>
      <h2>How to start</h2>
      <p>If you have been searching for a Bible study near you in Johannesburg or Sandton, here is the simplest path. Call Mr. Sim on +27 77 487 1295, or Ms. Dora on +27 67 442 4461, any weekday. Tell us you would like the Wednesday link. We will send it to you the morning of. Show up at 7:30pm. Stay until 9pm. See how it feels.</p>
      <p>If it feels right, come back next Wednesday. If it does not, you have lost nothing except ninety minutes on a weeknight, and you have a clearer answer than you had yesterday.</p>
    `,
  },
};

const post = posts[slug];

if (!post) {
  return Astro.redirect('/blog');
}

const schema = getBlogPostSchema(post.title, post.excerpt, post.date, 'Johannesburg Bible Study Church');
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  ogType="article"
  publishDate={post.date}
  schema={schema}
>
  <article class="section-padding">
    <div class="container-max max-w-3xl">
      <a href="/blog" class="text-sm text-blue-600 hover:underline mb-6 inline-block">Back to Blog</a>
      <p class="text-sm text-gray-500 mb-2">{post.date}</p>
      <h1 class="heading-1 mb-6">{post.title}</h1>
      <div class="flex flex-wrap gap-2 mb-8">
        {post.tags.map((tag) => (
          <span class="text-xs bg-blue-50 text-blue-700 px-3 py-1 rounded-full">{tag}</span>
        ))}
      </div>
      <div class="prose prose-lg max-w-none text-gray-700" set:html={post.content} />
    </div>
  </article>

  <section class="section-padding bg-gray-50">
    <div class="container-max max-w-3xl">
      <a href="/blog" class="btn-secondary">Back to All Posts</a>
    </div>
  </section>
</BaseLayout>
