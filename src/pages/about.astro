---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Johannesburg Bible Study Church | Sandton Christian Community"
  description="Learn about Johannesburg Bible Study Church — a Bible study and welcoming Christian community in Sandton, Johannesburg. Our beliefs, mission, and heart for the community."
>
  <section class="section-padding">
    <div class="container-max">
      <h1 class="heading-1 mb-6">About Johannesburg Bible Study Church</h1>
      <p class="text-body max-w-3xl mb-8">
        Johannesburg Bible Study Church is a Bible study and welcoming Christian community in Sandton, Johannesburg. We are committed to building a community where people grow in faith, serve one another, and extend God's love to the wider Johannesburg area.
      </p>
    </div>
  </section>

  <section class="section-padding bg-gray-50">
    <div class="container-max">
      <h2 class="heading-2 mb-8">What We Believe</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <div class="card">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-blue-100 text-blue-700 font-bold mb-3">B</div>
          <h3 class="heading-3 mb-3">The Bible</h3>
          <p class="text-sm text-gray-600">We believe the Bible is the inspired Word of God, our reliable guide for faith and daily life.</p>
        </div>
        <div class="card">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-blue-100 text-blue-700 font-bold mb-3">L</div>
          <h3 class="heading-3 mb-3">God's Love</h3>
          <p class="text-sm text-gray-600">We believe in a God who loves all people unconditionally and invites everyone into relationship with Him.</p>
        </div>
        <div class="card">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-blue-100 text-blue-700 font-bold mb-3">C</div>
          <h3 class="heading-3 mb-3">Community</h3>
          <p class="text-sm text-gray-600">We believe the church is a community where people grow together, support one another, and serve those around them.</p>
        </div>
        <div class="card">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-blue-100 text-blue-700 font-bold mb-3">S</div>
          <h3 class="heading-3 mb-3">Salvation</h3>
          <p class="text-sm text-gray-600">We believe salvation through Jesus Christ is available to all who turn to Him in faith and sincerity.</p>
        </div>
        <div class="card">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-blue-100 text-blue-700 font-bold mb-3">V</div>
          <h3 class="heading-3 mb-3">Service</h3>
          <p class="text-sm text-gray-600">We believe our faith calls us to serve our neighbours and community with practical love and generosity.</p>
        </div>
        <div class="card">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-blue-100 text-blue-700 font-bold mb-3">H</div>
          <h3 class="heading-3 mb-3">Hope</h3>
          <p class="text-sm text-gray-600">We believe in a future of hope and purpose, guided by God's plan and promises for every life.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-max">
      <h2 class="heading-2 mb-8">Our Mission</h2>
      <div class="max-w-3xl">
        <p class="text-lg text-gray-700 leading-relaxed mb-6">
          To be a welcoming Bible study community in Sandton, Johannesburg where people grow in their relationship with God, serve one another and the local community, and discover their purpose through spiritual education, fellowship, and practical service.
        </p>
        <p class="text-lg text-gray-700 leading-relaxed mb-8">
          Through our Wednesday online Bible study, free community classes, and youth programs, we aim to share God's love in practical ways that bless the people of Sandton and greater Johannesburg.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-blue-50">
    <div class="container-max text-center">
      <h2 class="heading-2 mb-4">Our Values</h2>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 max-w-4xl mx-auto">
        <div>
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-100 text-blue-700 font-bold mb-3">W</div>
          <h3 class="font-semibold text-gray-900 mb-1">Welcome</h3>
          <p class="text-sm text-gray-600">Everyone belongs here</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-100 text-blue-700 font-bold mb-3">T</div>
          <h3 class="font-semibold text-gray-900 mb-1">Truth</h3>
          <p class="text-sm text-gray-600">Grounded in Scripture</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-100 text-blue-700 font-bold mb-3">L</div>
          <h3 class="font-semibold text-gray-900 mb-1">Love</h3>
          <p class="text-sm text-gray-600">Practical, genuine care</p>
        </div>
        <div>
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-100 text-blue-700 font-bold mb-3">G</div>
          <h3 class="font-semibold text-gray-900 mb-1">Growth</h3>
          <p class="text-sm text-gray-600">Always learning together</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
