---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Events | Community Activities Sandton Johannesburg"
  description="Upcoming events and community activities from Johannesburg Bible Study Church in Sandton, Johannesburg. Bible study gatherings, community service, and youth programs."
>
  <section class="section-padding">
    <div class="container-max">
      <p class="text-blue-600 font-semibold uppercase tracking-wide text-sm mb-2">
        Events
      </p>
      <h1 class="heading-1 mb-6">Upcoming Events</h1>
      <p class="text-body max-w-2xl mb-8">
        Community activities, Bible study gatherings, and youth programs at Johannesburg Bible Study Church in Sandton, Johannesburg. Stay updated on what is happening in our community.
      </p>
    </div>
  </section>

  <section class="section-padding bg-gray-50">
    <div class="container-max">
      <div class="max-w-4xl mx-auto">
        <p class="text-center text-gray-500 py-12">
          Events will be listed here as they are scheduled. Regular activities include our Wednesday online Bible study and periodic community events.
        </p>

        <div class="space-y-6">
          <div class="card">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4">
              <div class="shrink-0 text-center bg-blue-50 rounded-xl px-4 py-3 w-fit">
                <p class="text-xs font-medium text-blue-600 uppercase">Every</p>
                <p class="text-2xl font-bold text-blue-700">Wed</p>
              </div>
              <div>
                <h3 class="heading-3 mb-2">Wednesday Online Bible Study</h3>
                <p class="text-sm text-gray-500 mb-2">Every Wednesday, 7:30pm — Online via Google Meet</p>
                <p class="text-sm text-gray-600">Our regular weekly Bible study. Join from anywhere in Johannesburg or beyond. Contact us for the meeting link.</p>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4">
              <div class="shrink-0 text-center bg-amber-50 rounded-xl px-4 py-3 w-fit">
                <p class="text-xs font-medium text-amber-600 uppercase">Every</p>
                <p class="text-2xl font-bold text-amber-700">Sun</p>
              </div>
              <div>
                <h3 class="heading-3 mb-2">Free Korean Class</h3>
                <p class="text-sm text-gray-500 mb-2">Every Sunday, 2:00pm — Parkmore, Sandton</p>
                <p class="text-sm text-gray-600">Free Korean language class open to all. Appointment required — call to register.</p>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4">
              <div class="shrink-0 text-center bg-green-50 rounded-xl px-4 py-3 w-fit">
                <p class="text-xs font-medium text-green-600 uppercase">Seasonal</p>
                <p class="text-2xl font-bold text-green-700">S/W</p>
              </div>
              <div>
                <h3 class="heading-3 mb-2">UseCan Youth Programs</h3>
                <p class="text-sm text-gray-500 mb-2">Summer and Winter schedule — Sandton, Johannesburg</p>
                <p class="text-sm text-gray-600">Youth empowerment, leadership training, and community service projects. Contact us for the upcoming program schedule.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding text-center">
    <div class="container-max">
      <h2 class="heading-2 mb-4">Stay Updated</h2>
      <p class="text-body max-w-xl mx-auto mb-6">
        Contact us to learn about upcoming events and community activities in Sandton, Johannesburg.
      </p>
      <a href="/contact" class="btn-primary">Contact Us</a>
    </div>
  </section>
</BaseLayout>
