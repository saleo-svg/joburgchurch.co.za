---
import BaseLayout from '@/layouts/BaseLayout.astro';

type GalleryImage = {
  src: string;
  alt: string;
  title: string;
  caption: string;
  category: string;
};

const images: GalleryImage[] = [
  {
    src: '/images/gallery-community.svg',
    alt: 'Community Fellowship — people gathered together',
    title: 'Community Fellowship',
    caption: 'A Sunday afternoon gathering at Parkmore, Sandton — the people who make up the Johannesburg Bible Study Church community.',
    category: 'Community',
  },
  {
    src: '/images/gallery-bible-study.svg',
    alt: 'The Bible Study — the Word together',
    title: 'The Word Together',
    caption: 'Wednesday evening Bible study on Google Meet — reading the same passage, asking the same questions, finding the same rest.',
    category: 'Bible Study',
  },
  {
    src: '/images/gallery-korean.svg',
    alt: 'Free Korean Class in Sandton Johannesburg',
    title: 'Korean Class, Sunday Afternoon',
    caption: 'Beginners welcome. The Hangul alphabet on day one. By the end of the first session, most students can read a Korean restaurant menu.',
    category: 'Korean Class',
  },
];

const categories = ['All', ...new Set(images.map((i) => i.category))];
---
<BaseLayout
  title="Gallery | Johannesburg Bible Study Church, Sandton"
  description="Photo gallery of Johannesburg Bible Study Church community life — Bible study gatherings, Korean class, youth events, and fellowship in Sandton, Johannesburg."
>
  <section class="section-padding">
    <div class="container-max">
      <p class="text-blue-600 font-semibold uppercase tracking-wide text-sm mb-2">
        Gallery
      </p>
      <h1 class="heading-1 mb-6">Community Life in Pictures</h1>
      <p class="text-body max-w-2xl mb-8">
        Moments from our Bible study, Korean class, youth events, and community gatherings in Sandton, Johannesburg. These images give you a sense of who shows up and what we do together.
      </p>
    </div>
  </section>

  <!-- Category filter (visual only — static for now) -->
  <section class="section-padding bg-gray-50">
    <div class="container-max">
      <div class="flex flex-wrap gap-3 mb-10">
        {categories.map((cat) => (
          <span class={`text-sm font-medium px-4 py-2 rounded-full cursor-pointer transition-colors ${cat === 'All' ? 'bg-blue-600 text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-blue-300'}`}>
            {cat}
          </span>
        ))}
      </div>

      <!-- Gallery grid -->
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {images.map((img) => (
          <article class="card overflow-hidden p-0 group">
            <div class="aspect-[4/3] overflow-hidden bg-gray-100">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs bg-blue-50 text-blue-700 px-3 py-1 rounded-full font-medium">
                  {img.category}
                </span>
              </div>
              <h3 class="heading-3 mb-2">{img.title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{img.caption}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Placeholder CTA -->
  <section class="section-padding text-center" style="background: linear-gradient(135deg, #1e3a5f 0%, #7c3aed 100%);">
    <div class="container-max">
      <h2 class="heading-2 text-white mb-4">Be Part of the Next Picture</h2>
      <p class="text-blue-100 text-lg mb-6 max-w-xl mx-auto">
        Our community grows one Wednesday at a time. Join the next Bible study and add your face to the story.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/visit" class="inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 text-sm font-semibold text-blue-700 shadow-sm transition-colors hover:bg-blue-50">
          Plan Your Visit
        </a>
        <a href="/contact" class="inline-flex items-center justify-center rounded-lg border border-white/40 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:bg-white/20">
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <!-- Coming soon note -->
  <section class="section-padding">
    <div class="container-max text-center">
      <div class="max-w-xl mx-auto">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-amber-100 text-amber-700 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h2 class="heading-2 mb-3">More Photos Coming Soon</h2>
        <p class="text-body">
          We are building a photo archive of community events and gatherings. Real photos will be added as they become available. In the meantime, these illustrations represent the spirit of our community.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
