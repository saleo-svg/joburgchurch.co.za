---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Youth Programs UseCan | Christian Youth Community Sandton Johannesburg"
  description="UseCan youth programs in Sandton, Johannesburg. Youth empowerment, leadership, and community service for young people. Summer and winter programs available."
>
  <section class="section-padding bg-amber-50">
    <div class="container-max">
      <p class="text-amber-600 font-semibold uppercase tracking-wide text-sm mb-2">
        Youth & UseCan
      </p>
      <h1 class="heading-1 mb-6">Youth Programs in Sandton, Johannesburg</h1>
      <p class="text-body max-w-3xl mb-8">
        Our youth programs create space for young people in Sandton and the wider Johannesburg area to grow spiritually, build friendships, discover their gifts, and serve the community with purpose.
      </p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-max">
      <div class="grid gap-12 lg:grid-cols-2 items-center mb-16">
        <div>
          <div class="bg-amber-100 rounded-2xl p-8">
            <h2 class="heading-2 mb-4">UseCan — You Can</h2>
            <p class="text-body mb-4">
              UseCan is our youth empowerment initiative. The name says it all: we believe every young person has potential and can make a difference.
            </p>
            <ul class="space-y-2 text-gray-700">
              <li class="flex gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Personal growth and self-confidence
              </li>
              <li class="flex gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Leadership development
              </li>
              <li class="flex gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Practical life skills
              </li>
              <li class="flex gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Community service projects
              </li>
              <li class="flex gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Faith and character building
              </li>
            </ul>
          </div>
        </div>
        <div class="space-y-6">
          <div class="card">
            <h3 class="heading-3 mb-2">Youth Gatherings</h3>
            <p class="text-sm text-gray-600 mb-2">
              Regular gatherings where young people come together for worship, teaching, fun activities, and fellowship in the Sandton area.
            </p>
            <p class="text-xs text-amber-600 font-semibold">Summer / Winter schedule</p>
          </div>
          <div class="card">
            <h3 class="heading-3 mb-2">Leadership Training</h3>
            <p class="text-sm text-gray-600 mb-2">
              Equipping young people to lead in their schools, families, and communities with integrity and purpose.
            </p>
            <p class="text-xs text-amber-600 font-semibold">Contact us for schedule</p>
          </div>
          <div class="card">
            <h3 class="heading-3 mb-2">Service Projects</h3>
            <p class="text-sm text-gray-600 mb-2">
              Hands-on opportunities to serve the local Sandton and Johannesburg community.
            </p>
            <p class="text-xs text-amber-600 font-semibold">See our Events page for upcoming projects</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-gray-50">
    <div class="container-max">
      <h2 class="heading-2 mb-8 text-center">Who Can Join?</h2>
      <div class="grid gap-6 sm:grid-cols-3 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-amber-100 text-amber-700 font-bold mb-3">TS</div>
          <h3 class="font-semibold text-gray-900 mb-1">Teenagers</h3>
          <p class="text-sm text-gray-600">High school students</p>
        </div>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-amber-100 text-amber-700 font-bold mb-3">YA</div>
          <h3 class="font-semibold text-gray-900 mb-1">Young Adults</h3>
          <p class="text-sm text-gray-600">University and post-school</p>
        </div>
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-amber-100 text-amber-700 font-bold mb-3">AL</div>
          <h3 class="font-semibold text-gray-900 mb-1">Everyone</h3>
          <p class="text-sm text-gray-600">No church background needed</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-amber-600 text-white text-center">
    <div class="container-max">
      <h2 class="heading-2 text-white mb-4">Get Involved</h2>
      <p class="text-amber-100 text-lg mb-6 max-w-xl mx-auto">
        Whether you are a young person looking for community, or a parent wanting to know more about our programs — we would love to hear from you.
      </p>
      <a href="/contact" class="btn-warm bg-white text-amber-700 hover:bg-amber-50">Contact Us</a>
    </div>
  </section>
</BaseLayout>
